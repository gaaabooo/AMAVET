generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid())
  nombre      String
  email       String    @unique
  telefono    String
  password    String
  rol         Rol       @default(TUTOR)
  // Se incrementa al cambiar la contraseña. El JWT lleva este valor en el claim
  // "tv"; si no coincide, JwtStrategy rechaza el token. Permite invalidar
  // sesiones previas sin mantener una lista de tokens emitidos.
  tokenVersion Int      @default(0)
  mascotas    Mascota[]
  creadoEn    DateTime  @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([rol])
}

model Mascota {
  id            String    @id @default(uuid())
  numero        Int       @unique @default(autoincrement())
  nombre        String
  tipo          String
  raza          String?
  edad          Int?
  tutorId       String
  tutor         User      @relation(fields: [tutorId], references: [id])
  examenes      Examen[]
  citas         Cita[]
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@index([tutorId])
}

model Examen {
  id            String       @id @default(uuid())
  tipo          String
  estado        EstadoExamen @default(PENDIENTE)
  archivoUrl    String?
  mascotaId     String
  mascota       Mascota      @relation(fields: [mascotaId], references: [id], onDelete: Cascade)
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  @@index([mascotaId])
  @@index([estado])
}

model Cita {
  id            String     @id @default(uuid())
  fecha         DateTime
  direccion     String
  servicios     String[]
  estado        EstadoCita @default(PENDIENTE)
  mascotaId     String
  mascota       Mascota    @relation(fields: [mascotaId], references: [id], onDelete: Cascade)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  @@index([mascotaId])
  @@index([fecha])
  @@index([estado])
}

enum Rol {
  TUTOR
  ADMIN
}

enum EstadoExamen {
  PENDIENTE
  EN_PROCESO
  DISPONIBLE
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  COMPLETADA
  CANCELADA
}
