generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid())
  nombre      String
  email       String    @unique
  telefono    String
  password    String
  rol         Rol       @default(TUTOR)
  // Origen de la cuenta. LOCAL: registro con email + contraseña. GOOGLE: cuenta
  // creada vía OAuth de Google, sin contraseña propia utilizable. Reemplaza la
  // heurística antigua (telefono === 'PENDIENTE') para decidir si una cuenta
  // puede recuperar contraseña.
  proveedor   Proveedor @default(LOCAL)
  // Se incrementa al cambiar la contraseña. El JWT lleva este valor en el claim
  // "tv"; si no coincide, JwtStrategy rechaza el token. Permite invalidar
  // sesiones previas sin mantener una lista de tokens emitidos.
  tokenVersion Int      @default(0)
  // Soft-delete. null = cuenta activa. Cuando el usuario elimina su cuenta se
  // marca con la fecha; tras 30 días un proceso de purga la borra de forma
  // definitiva. Durante ese plazo el login está bloqueado pero la cuenta puede
  // reactivarse iniciando sesión con las credenciales correctas.
  eliminadoEn DateTime?
  mascotas    Mascota[]
  resetTokens PasswordResetToken[]
  creadoEn    DateTime  @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([rol])
  @@index([eliminadoEn])
}

model Mascota {
  id            String    @id @default(uuid())
  numero        Int       @unique @default(autoincrement())
  nombre        String
  tipo          String
  raza          String?
  edad          Int?
  tutorId       String
  tutor         User      @relation(fields: [tutorId], references: [id])
  examenes      Examen[]
  citas         Cita[]
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@index([tutorId])
}

model Examen {
  id            String       @id @default(uuid())
  tipo          String
  estado        EstadoExamen @default(PENDIENTE)
  archivoUrl    String?
  mascotaId     String
  mascota       Mascota      @relation(fields: [mascotaId], references: [id], onDelete: Cascade)
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  @@index([mascotaId])
  @@index([estado])
}

model Cita {
  id            String     @id @default(uuid())
  fecha         DateTime
  direccion     String
  servicios     String[]
  estado        EstadoCita @default(PENDIENTE)
  mascotaId     String
  mascota       Mascota    @relation(fields: [mascotaId], references: [id], onDelete: Cascade)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  @@index([mascotaId])
  @@index([fecha])
  @@index([estado])
}

model PasswordResetToken {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  expiraEn    DateTime
  usado       Boolean  @default(false)
  ipSolicitud String?
  creadoEn    DateTime @default(now())

  @@index([userId])
  @@index([expiraEn])
}

// Registro de intentos de login para el lockout escalonado. Cada fallo deja una
// fila; el bloqueo se evalúa por la combinación email+ip. Un login exitoso
// borra los intentos de esa combinación. Las filas viejas se purgan de forma
// oportunista al consultar.
model LoginIntento {
  id        String   @id @default(uuid())
  email     String
  ip        String
  exitoso   Boolean
  creadoEn  DateTime @default(now())

  @@index([email, ip, creadoEn])
  @@index([creadoEn])
}

// Bitácora de seguridad persistente. Cada evento auditable (login, registro,
// cambios de cuenta, etc.) deja una fila aquí además del log a stdout. Permite
// consultar el historial desde el panel de admin, detectar patrones
// sospechosos y conservar trazas para análisis forense (retención 90 días).
model AuditLog {
  id        String   @id @default(uuid())
  // Nombre del evento (EventoAuditoria): LOGIN_OK, LOGIN_FALLIDO, etc.
  evento    String
  // true para eventos sospechosos/fallidos (alertar), false para eventos OK.
  alerta    Boolean  @default(false)
  // userId asociado al evento, si aplica.
  userId    String?
  // IP de origen, si aplica.
  ip        String?
  // Resto de datos del evento, como JSON (sin PII cruda: emails enmascarados).
  datos     Json?
  creadoEn  DateTime @default(now())

  @@index([evento, creadoEn])
  @@index([userId, creadoEn])
  @@index([creadoEn])
  // Para la detección de fuerza bruta, que filtra por ip + evento + ventana.
  @@index([ip, evento, creadoEn])
  // Para la detección de login desde IP nueva, que cuenta logins de un usuario
  // por evento (y opcionalmente por ip).
  @@index([userId, evento, ip])
}

enum Rol {
  TUTOR
  ADMIN
}

enum Proveedor {
  LOCAL
  GOOGLE
}

enum EstadoExamen {
  PENDIENTE
  EN_PROCESO
  DISPONIBLE
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  COMPLETADA
  CANCELADA
}
