# ===== Base de datos =====
DATABASE_URL=postgresql://user:password@host:5432/database

# ===== Auth =====
# JWT_SECRET: mínimo 32 caracteres aleatorios. Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_minimo_32_caracteres_aleatorios
JWT_EXPIRES_IN=7d

# ===== Servidor =====
PORT=3001

# ===== CORS =====
# Lista separada por comas con URLs permitidas (sin slash final). Ejemplo:
#   FRONTEND_URL=https://vet.silvestra.cl,https://www.vet.silvestra.cl
FRONTEND_URL=
# Patrón regex opcional para permitir previews de Vercel concretos. Ejemplo
# que permite SOLO los previews del proyecto amavet (NO cualquier .vercel.app):
#   ALLOWED_VERCEL_PATTERN=^https://amavet-[a-z0-9-]+\.vercel\.app$
ALLOWED_VERCEL_PATTERN=

# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ===== Email (SMTP) =====
#
# OPCIÓN A — Gmail con App Password (sin dominio propio, para desarrollo/demo)
# 1. Crea una cuenta Gmail dedicada: notificaciones.amavet@gmail.com
# 2. Activa verificación en 2 pasos en esa cuenta
# 3. Ve a myaccount.google.com → Seguridad → Contraseñas de aplicación
# 4. Genera una contraseña de 16 caracteres para "Correo / Windows"
# 5. Úsala en SMTP_PASS (sin espacios)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=notificaciones.amavet@gmail.com
SMTP_PASS=abcdabcdabcdabcd
SMTP_FROM=AMAVET <notificaciones.amavet@gmail.com>
#
# OPCIÓN B — Resend con dominio propio (producción)
# Requiere dominio verificado en resend.com
#
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxx
# SMTP_FROM=AMAVET <notificaciones@vet.silvestra.cl>
