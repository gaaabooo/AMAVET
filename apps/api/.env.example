# ===== Base de datos =====
DATABASE_URL=postgresql://user:password@host:5432/database

# ===== Auth =====
# JWT_SECRET: mínimo 32 caracteres aleatorios. Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_minimo_32_caracteres_aleatorios
JWT_EXPIRES_IN=24h

# ===== Servidor =====
PORT=3001

# ===== CORS =====
# Lista separada por comas con URLs permitidas (sin slash final). Ejemplo:
#   FRONTEND_URL=https://vet.silvestra.cl,https://www.vet.silvestra.cl
FRONTEND_URL=
# Patrón regex opcional para permitir previews de Vercel concretos. Ejemplo
# que permite SOLO los previews del proyecto amavet (NO cualquier .vercel.app):
#   ALLOWED_VERCEL_PATTERN=^https://amavet-[a-z0-9-]+\.vercel\.app$
ALLOWED_VERCEL_PATTERN=

# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ===== Email (SendGrid, API HTTP) =====
# Se usa la API HTTP de SendGrid (puerto 443) en lugar de SMTP, porque muchos
# hostings (Render free, etc.) bloquean el SMTP saliente.
#
# 1. Crea una cuenta en https://sendgrid.com
# 2. Settings → Sender Authentication → "Verify a Single Sender": verifica un
#    email tuyo (recibirás un correo de confirmación). Con un single sender ya
#    puedes enviar a CUALQUIER destinatario.
# 3. Settings → API Keys → Create API Key (permiso "Mail Send" basta).
# 4. En producción, idealmente verifica un dominio propio en SendGrid en lugar
#    de un Gmail (mejora la entregabilidad): SENDGRID_FROM=Silvestra Vet <noreply@tu-dominio.com>
#
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=Silvestra Vet <notificaciones.silvestra@gmail.com>
